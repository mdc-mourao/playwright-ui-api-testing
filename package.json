{
  "name": "playwright-ui-api-testing",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:all": "npx playwright test",
    "test:api": "npx playwright test --project=API-Tests",
    "test:ui": "npx playwright test --grep='@UI'",
    "test:chromium": "npx playwright test --project='UI-Chromium'",
    "test:webkit": "npx playwright test --project='UI-WebKit'",
    "test:firefox": "npx playwright test --project='UI-Firefox'",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:clean": "rm -rf allure-results allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "lint:report": "eslint . --format html --output-file lint-report.html",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdc-mourao/playwright-ui-api-testing.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mdc-mourao/playwright-ui-api-testing/issues"
  },
  "homepage": "https://github.com/mdc-mourao/playwright-ui-api-testing#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.6.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-ajv-errors": "^2.0.3"
  }
}
